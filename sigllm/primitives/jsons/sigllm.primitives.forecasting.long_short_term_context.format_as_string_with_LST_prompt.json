{
    "name": "sigllm.primitives.forecasting.long_short_term_context.format_as_string_with_LST_prompt",
    "contributors": [
        "Allen Baranov <baranov@mit.edu>"
    ],
    "description": "Format X to string(s) with LST prompt. Formats long-term and short-term context separately and combines them with a prompt.",
    "classifiers": {
